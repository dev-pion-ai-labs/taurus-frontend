# ---------------------------------------------------------------------------
# Local development environment variables
# Copy this file to .env.local and adjust values as needed.
# .env.local is git-ignored and never committed.
# ---------------------------------------------------------------------------

# Backend URL (server-side only, used by Next.js rewrites to proxy /api/v1).
# Defaults to http://localhost:3000 if unset.
#
# LOCAL DEVELOPMENT — usually leave unset (default points at local NestJS).
# BACKEND_URL=http://localhost:3000
#
# PRODUCTION (Railway) — set in the Railway dashboard:
# BACKEND_URL=http://taurus-backend.railway.internal:3000
