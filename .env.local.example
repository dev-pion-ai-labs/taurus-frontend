# ---------------------------------------------------------------------------
# Local development environment variables
# Copy this file to .env.local and adjust values as needed.
# .env.local is git-ignored and never committed.
# ---------------------------------------------------------------------------

# API base URL used by the Next.js frontend.
#
# LOCAL DEVELOPMENT
# Leave this unset (or use the value below) to let Next.js proxy /api/v1
# requests to the local backend via the rewrite rule in next.config.ts.
# The rewrite target defaults to http://localhost:3000, matching the default
# NestJS port for taurus-backend.
#
# Uncomment only if you need to point directly at the local backend instead
# of using the proxy (e.g. when debugging CORS or network issues):
# NEXT_PUBLIC_API_URL=http://localhost:3000/api/v1

# PRODUCTION (Railway)
# Set this variable in the Railway dashboard / service environment so the
# frontend calls the backend over the private Railway network:
# NEXT_PUBLIC_API_URL=http://taurus-backend.railway.internal/api/v1
